# docker-compose 용 환경변수 예시
# 사용법: cp .env.docker.example .env  (도커 컴포즈는 자동으로 .env 로드)

# --- DB ---
DB_NAME=market_mvp
DB_PASSWORD=rootpass

# --- JWT ---
SECRET_KEY=dev-secret-change-me

# --- 외부 API (선택, 없으면 fallback) ---
KAMIS_API_KEY=
KAMIS_API_ID=
KAMIS_CERT_ID=
ANTHROPIC_API_KEY=
SEOUL_API_KEY=
